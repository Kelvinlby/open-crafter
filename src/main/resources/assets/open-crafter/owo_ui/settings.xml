<?xml version="1.0" encoding="UTF-8"?>
<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo-lib/1.20/owo-ui.xsd">
    <components>
        <!-- Main vertical flow container -->
        <flow-layout direction="vertical">
            <children>
                <!-- Settings Panel -->
                <flow-layout direction="vertical">
                    <children>
                        <!-- Title -->
                        <label id="title-label">
                            <text>§l§6Settings</text>
                            <horizontal-alignment>center</horizontal-alignment>
                        </label>

                        <!-- Divider -->
                        <flow-layout direction="horizontal">
                            <children>
                                <box>
                                    <color>#40FFFFFF</color>
                                    <fill>true</fill>
                                    <sizing>
                                        <horizontal method="fixed">200</horizontal>
                                        <vertical method="fixed">2</vertical>
                                    </sizing>
                                </box>
                            </children>
                        </flow-layout>

                        <!-- Player Name Setting -->
                        <flow-layout direction="vertical">
                            <children>
                                <label id="player-name-label">
                                    <text>Player Name:</text>
                                </label>
                                <text-box id="player-name-input">
                                    <text></text>
                                    <sizing>
                                        <horizontal method="fixed">200</horizontal>
                                    </sizing>
                                </text-box>
                            </children>
                            <gap>5</gap>
                        </flow-layout>

                        <!-- Volume Setting -->
                        <flow-layout direction="vertical">
                            <children>
                                <flow-layout direction="horizontal">
                                    <children>
                                        <label id="volume-label">
                                            <text>Volume: </text>
                                        </label>
                                        <label id="volume-value">
                                            <text>50</text>
                                        </label>
                                        <label>
                                            <text>%</text>
                                        </label>
                                    </children>
                                    <gap>2</gap>
                                </flow-layout>
                                <slider id="volume-slider">
                                    <value>0.5</value>
                                    <sizing>
                                        <horizontal method="fixed">200</horizontal>
                                    </sizing>
                                </slider>
                            </children>
                            <gap>5</gap>
                        </flow-layout>

                        <!-- Toggle Settings -->
                        <flow-layout direction="vertical">
                            <children>
                                <checkbox id="enable-notifications">
                                    <text>Enable Notifications</text>
                                    <checked>true</checked>
                                </checkbox>

                                <checkbox id="auto-save">
                                    <text>Auto-Save Enabled</text>
                                    <checked>false</checked>
                                </checkbox>

                                <checkbox id="dark-mode">
                                    <text>Dark Mode</text>
                                    <checked>false</checked>
                                </checkbox>
                            </children>
                            <gap>8</gap>
                        </flow-layout>

                        <!-- Action Buttons -->
                        <flow-layout direction="horizontal">
                            <children>
                                <button id="save-button">
                                    <text>§aSave</text>
                                    <sizing>
                                        <horizontal method="fixed">80</horizontal>
                                    </sizing>
                                </button>

                                <button id="reset-button">
                                    <text>§eReset</text>
                                    <sizing>
                                        <horizontal method="fixed">80</horizontal>
                                    </sizing>
                                </button>

                                <button id="close-button">
                                    <text>§cClose</text>
                                    <sizing>
                                        <horizontal method="fixed">80</horizontal>
                                    </sizing>
                                </button>
                            </children>
                            <gap>10</gap>
                            <padding>
                                <top>10</top>
                            </padding>
                        </flow-layout>
                    </children>
                    <surface>
                        <vanilla-translucent/>
                    </surface>
                    <padding>
                        <all>20</all>
                    </padding>
                    <gap>15</gap>
                    <sizing>
                        <horizontal method="content">0</horizontal>
                        <vertical method="content">0</vertical>
                    </sizing>
                </flow-layout>
            </children>
            <sizing>
                <horizontal method="fill">100</horizontal>
                <vertical method="fill">100</vertical>
            </sizing>
            <horizontal-alignment>center</horizontal-alignment>
            <vertical-alignment>center</vertical-alignment>
        </flow-layout>
    </components>
</owo-ui>
